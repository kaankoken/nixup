{
  "_comment": "Soft sandbox for Pi goal harness. Schema is provisional until the MCP/sandbox adapter documents official keys; activation may remap. Project .pi/sandbox.json wins on merge.",
  "mode": "soft",
  "allowedPaths": [
    "${PROJECT_ROOT}",
    "${PROJECT_ROOT}/.git",
    "${WORKTREE_ROOT}",
    "${HOME}/.local/bin",
    "${HOME}/.bun/bin",
    "${HOME}/.cargo/bin",
    "${HOME}/.pi",
    "${HOME}/.agents",
    "${HOME}/.claude/skills",
    "${HOME}/.claude/plugins/cache",
    "/opt/homebrew/bin",
    "/usr/local/bin",
    "/nix/var/nix/profiles",
    "/run/current-system/sw/bin"
  ],
  "blockedPaths": [
    "${HOME}",
    "${HOME}/.ssh",
    "${HOME}/.gnupg",
    "${HOME}/.aws",
    "${HOME}/.config",
    "${HOME}/Library",
    "/etc",
    "/usr",
    "/System",
    "/var"
  ],
  "blockedPathExceptions": [
    "${HOME}/.local/bin",
    "${HOME}/.bun/bin",
    "${HOME}/.cargo/bin",
    "${HOME}/.pi",
    "${HOME}/.agents",
    "${HOME}/.claude/skills",
    "${HOME}/.claude/plugins/cache"
  ],
  "allowNetwork": true,
  "networkAllowlist": [
    "registry.npmjs.org",
    "registry.yarnpkg.com",
    "pypi.org",
    "files.pythonhosted.org",
    "crates.io",
    "static.crates.io",
    "index.crates.io",
    "proxy.golang.org",
    "sum.golang.org",
    "repo.maven.apache.org",
    "api.github.com",
    "github.com",
    "raw.githubusercontent.com",
    "mcp.context7.com",
    "api.openai.com",
    "api.anthropic.com",
    "api.x.ai",
    "api.cursor.com"
  ],
  "denyArbitraryHomeWrites": true,
  "allowProjectWrites": true,
  "allowWorktreeWrites": true
}
